{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "SECRET_KEY": "5fdbfffc1663bcdecf3c19036ed597121363518f1ead170108d7992dda94e14f",
    "UPLOAD_FOLDER": "/tmp/uploads",
    "DATABASE_PATH": "/tmp/vault.db"
  }
}
